<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Todo App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Todo App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar">
      <div class="navbar-brand">
        <%= link_to "TodoApp", root_path, class: "navbar-logo" %>
      </div>
      <div class="navbar-menu">
        <% if user_signed_in? %>
          <span class="navbar-user"><%= current_user.email %></span>
          <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline" %>
        <% else %>
          <%= link_to "ログイン", new_user_session_path, class: "btn btn-outline" %>
          <%= link_to "新規登録", new_user_registration_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    </nav>

    <div class="container">
      <% if notice %>
        <div class="flash flash-notice" data-controller="flash">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="flash flash-alert" data-controller="flash">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
